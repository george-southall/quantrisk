# Streamlit Cloud secrets template
# ─────────────────────────────────────────────────────────────────────────────
# DO NOT rename this file to secrets.toml — that file is gitignored for safety.
#
# To deploy on Streamlit Community Cloud:
#   1. Go to your app → Settings → Secrets
#   2. Paste the content below (with your real values filled in)
#
# Streamlit exposes these as environment variables, so pydantic-settings
# picks them up automatically — no code changes needed.
# ─────────────────────────────────────────────────────────────────────────────

FRED_API_KEY = "your_fred_api_key_here"

# Optional overrides (these all have sensible defaults):
# DEFAULT_START_DATE = "2015-01-01"
# DEFAULT_BENCHMARK = "SPY"
# MC_NUM_SIMULATIONS = "10000"
# RISK_FREE_RATE_FALLBACK = "0.05"
